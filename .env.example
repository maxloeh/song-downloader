# ─────────────────────────────────────────────────────────────────────────────
# Self-Hosted Music Downloader — configuration
# Copy this file to `.env` and fill in the values. Never commit your real `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Auth (OPTIONAL). Leave unset to create your account in the app on first run
# (recommended). If set, these act as a fallback admin login.
# APP_USERNAME=changeme
# APP_PASSWORD=changeme

# Spotify Developer credentials (strongly recommended for reliable Spotify
# metadata). Create a free app at https://developer.spotify.com/dashboard and
# paste the Client ID / Client Secret here. Without these, the Spotify path
# falls back to spotDL's lighter no-API client and is less reliable.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# SoundCloud (optional) — only needed for original-quality / private downloads.
# This is the `oauth_token` cookie value from a logged-in SoundCloud session.
SOUNDCLOUD_AUTH_TOKEN=

# Behavior
MAX_CONCURRENT_DOWNLOADS=3
DEFAULT_FORMAT=mp3
DEFAULT_BITRATE=320k
DOWNLOAD_DIR=/downloads
# yt-dlp output template (per-track path under DOWNLOAD_DIR).
OUTPUT_TEMPLATE=%(playlist_title)s/%(title)s.%(ext)s

# spotDL audio provider fallback order (comma-separated).
SPOTDL_AUDIO_PROVIDERS=youtube-music,youtube

# Maintenance
# Run `pip install -U yt-dlp spotdl` on container start. yt-dlp breaks whenever
# YouTube/SoundCloud change their sites, so keeping it fresh is important.
YTDLP_AUTO_UPDATE=true

# Auto-stop after this many minutes with no requests and no active downloads
# (0 disables). Great with the launcher (--restart no). Set 0 for an always-on
# host using restart: unless-stopped, or it will exit and immediately restart.
IDLE_SHUTDOWN_MINUTES=30

# Server
HOST=0.0.0.0
PORT=8080
